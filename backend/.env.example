# ============================================================
# MixMind AI - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values.
#   cp .env.example .env
# ============================================================

# --- Application --------------------------------------------------
APP_NAME=MixMind AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
LOG_JSON_FORMAT=false

# --- API ----------------------------------------------------------
API_V1_PREFIX=/api/v1
BASE_URL=http://localhost:8000
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DEMO_BUCKET=mixmind-media
DEMO_SIGNED_URL_TTL=3600
DEMO_MANIFEST_CACHE_TTL=300

# --- CORS ---------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# --- Paths --------------------------------------------------------
UPLOAD_DIR=uploads
PROCESSED_DIR=processed
TEMP_DIR=temp

# --- Upload Limits ------------------------------------------------
MAX_UPLOAD_SIZE=100

# --- LLM / OpenRouter ---------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-235b-a22b:free

LLM_TIMEOUT=30
LLM_MAX_RETRIES=2
LLM_RETRY_BACKOFF_BASE=1.0
LLM_MAX_TOKENS=1500
LLM_TEMPERATURE=0.0
LLM_LOG_RAW_RESPONSES=false
